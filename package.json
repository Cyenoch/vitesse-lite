{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "dev": "vp dev --port 3333 --open",
    "lint": "vp lint",
    "preview": "vp preview",
    "typecheck": "vp check --no-fmt --no-lint"
  },
  "dependencies": {
    "@pinia/colada": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.19",
    "@iconify-json/line-md": "^1.2.16",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-legacy": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "postcss": "^8.5.8",
    "postcss-preset-env": "^11.2.0",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-turbo-console": "^2.3.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plus": "latest",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "browserslist": {
    "production": [
      "defaults",
      "not IE 11",
      "Android >= 8",
      "iOS >= 12",
      "Safari >= 12",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vite": "*"
      }
    },
    "onlyBuiltDependencies": [
      "vue-demi"
    ]
  }
}
